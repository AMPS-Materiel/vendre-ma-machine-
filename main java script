/* ─── STORAGE HELPERS ─── */
const DB = {
  init() {
    if (!localStorage.getItem('vmm_annonces')) {
      localStorage.setItem('vmm_annonces', JSON.stringify(SAMPLE_ANNONCES));
    }
    if (!localStorage.getItem('vmm_users')) {
      localStorage.setItem('vmm_users', JSON.stringify(SAMPLE_USERS));
    }
  },
  getAnnonces() { return JSON.parse(localStorage.getItem('vmm_annonces') || '[]'); },
  saveAnnonces(data) { localStorage.setItem('vmm_annonces', JSON.stringify(data)); },
  getUsers() { return JSON.parse(localStorage.getItem('vmm_users') || '[]'); },
  saveUsers(data) { localStorage.setItem('vmm_users', JSON.stringify(data)); },
  getSession() { return JSON.parse(sessionStorage.getItem('vmm_session') || 'null'); },
  setSession(user) { sessionStorage.setItem('vmm_session', JSON.stringify(user)); },
  clearSession() { sessionStorage.removeItem('vmm_session'); },

  getApprovedAnnonces() {
    return this.getAnnonces().filter(a => a.statut === 'approved');
  },
  getAnnonce(id) {
    return this.getAnnonces().find(a => a.id === parseInt(id));
  },
  addAnnonce(data) {
    const annonces = this.getAnnonces();
    const newId = Math.max(...annonces.map(a => a.id), 0) + 1;
    const annonce = { ...data, id: newId, statut: 'pending', date: new Date().toISOString().split('T')[0], vues: 0 };
    annonces.push(annonce);
    this.saveAnnonces(annonces);
    return annonce;
  },
  updateAnnonce(id, data) {
    const annonces = this.getAnnonces();
    const idx = annonces.findIndex(a => a.id === parseInt(id));
    if (idx >= 0) { annonces[idx] = { ...annonces[idx], ...data }; this.saveAnnonces(annonces); }
  },
  deleteAnnonce(id) {
    const annonces = this.getAnnonces().filter(a => a.id !== parseInt(id));
    this.saveAnnonces(annonces);
  },
  login(email, mdp) {
    const users = this.getUsers();
    return users.find(u => u.email === email && u.mdp === mdp) || null;
  },
  register(nom, email, mdp) {
    const users = this.getUsers();
    if (users.find(u => u.email === email)) return null;
    const newId = Math.max(...users.map(u => u.id), 0) + 1;
    const user = { id: newId, nom, email, mdp, role: 'user', dateInscription: new Date().toISOString().split('T')[0], annonces: 0 };
    users.push(user);
    this.saveUsers(users);
    return user;
  }
};

/* ─── TOAST NOTIFICATIONS ─── */
function showToast(type, title, msg) {
  let container = document.getElementById('toast-container');
  if (!container) {
    container = document.createElement('div');
    container.id = 'toast-container';
    container.className = 'toast-container';
    document.body.appendChild(container);
  }
  const colors = { success: '#0F9B6A', error: '#D43030', warning: '#E8A500', info: '#2E6FD8' };
  const toast = document.createElement('div');
  toast.className = `toast toast--${type}`;
  toast.innerHTML = `
    <svg class="toast__icon" viewBox="0 0 24 24" style="fill:${colors[type]||colors.info}">
      ${type==='success'?ICONS.check:type==='error'?ICONS.close:ICONS.info}
    </svg>
    <div class="toast__body">
      <div class="toast__title">${title}</div>
      ${msg ? `<div class="toast__msg">${msg}</div>` : ''}
    </div>
    <button class="toast__close" onclick="this.closest('.toast').remove()">✕</button>`;
  container.appendChild(toast);
  setTimeout(() => toast.remove(), 4500);
}

/* ─── NAVBAR HELPERS ─── */
function updateNavbar() {
  const session = DB.getSession();
  const navUser = document.getElementById('nav-user');
  const navAdmin = document.getElementById('nav-admin');
  const navLogin = document.getElementById('nav-login');
  if (!navUser) return;
  if (session) {
    navUser.textContent = session.nom.split(' ')[0];
    navUser.href = 'compte.html';
    navUser.style.display = 'inline-flex';
    if (navAdmin) navAdmin.style.display = session.role === 'admin' ? 'inline-flex' : 'none';
    if (navLogin) navLogin.textContent = 'Déconnexion';
    if (navLogin) navLogin.onclick = (e) => { e.preventDefault(); DB.clearSession(); location.reload(); };
  } else {
    navUser.style.display = 'none';
    if (navAdmin) navAdmin.style.display = 'none';
    if (navLogin) navLogin.href = 'connexion.html';
    if (navLogin) navLogin.textContent = 'Connexion';
  }
}

/* ─── MOBILE MENU ─── */
function initMobileMenu() {
  const btn = document.getElementById('hamburger');
  const menu = document.getElementById('mobile-menu');
  if (btn && menu) {
    btn.addEventListener('click', () => { menu.style.display = menu.style.display === 'block' ? 'none' : 'block'; });
  }
}

