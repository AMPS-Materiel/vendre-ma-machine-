/* ─── PRICE FORMATTER ─── */
function formatPrice(p) {
  return Number(p).toLocaleString('fr-FR') + ' €';
}

/* ─── DATE FORMATTER ─── */
function formatDate(d) {
  return new Date(d).toLocaleDateString('fr-FR', { day: '2-digit', month: 'long', year: 'numeric' });
}

/* ─── SEARCH ─── */
function searchAnnonces(query, filters = {}) {
  let annonces = DB.getApprovedAnnonces();
  if (query) {
    const q = query.toLowerCase();
    annonces = annonces.filter(a =>
      a.titre.toLowerCase().includes(q) ||
      a.marque.toLowerCase().includes(q) ||
      a.modele.toLowerCase().includes(q) ||
      a.description.toLowerCase().includes(q) ||
      a.categorie.toLowerCase().includes(q)
    );
  }
  if (filters.categorie) annonces = annonces.filter(a => a.categorie === filters.categorie);
  if (filters.etat) annonces = annonces.filter(a => a.etat === filters.etat);
  if (filters.prixMin) annonces = annonces.filter(a => a.prix >= parseFloat(filters.prixMin));
  if (filters.prixMax) annonces = annonces.filter(a => a.prix <= parseFloat(filters.prixMax));
  if (filters.anneeMin) annonces = annonces.filter(a => a.annee >= parseInt(filters.anneeMin));
  if (filters.anneeMax) annonces = annonces.filter(a => a.annee <= parseInt(filters.anneeMax));
  if (filters.localisation) annonces = annonces.filter(a => a.localisation.toLowerCase().includes(filters.localisation.toLowerCase()));
  if (filters.sort === 'prix_asc') annonces.sort((a,b) => a.prix - b.prix);
  else if (filters.sort === 'prix_desc') annonces.sort((a,b) => b.prix - a.prix);
  else if (filters.sort === 'date_desc') annonces.sort((a,b) => b.date.localeCompare(a.date));
  else if (filters.sort === 'date_asc') annonces.sort((a,b) => a.date.localeCompare(b.date));
  else annonces.sort((a,b) => b.date.localeCompare(a.date));
  return annonces;
}

/* ─── URL PARAMS ─── */
function getParam(name) {
  return new URLSearchParams(window.location.search).get(name);
}

/* ─── REQUIRE AUTH ─── */
function requireAuth(role) {
  const session = DB.getSession();
  if (!session) { window.location.href = 'connexion.html'; return null; }
  if (role === 'admin' && session.role !== 'admin') { window.location.href = 'index.html'; return null; }
  return session;
}

