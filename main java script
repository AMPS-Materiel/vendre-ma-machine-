/* ─── INJECT NAVBAR/FOOTER ─── */
function injectLayout() {
  const navEl = document.getElementById('navbar-placeholder');
  const footerEl = document.getElementById('footer-placeholder');
  if (navEl) navEl.innerHTML = NAVBAR_HTML;
  if (footerEl) footerEl.innerHTML = FOOTER_HTML;
  updateNavbar();
  initMobileMenu();
  const searchInput = document.getElementById('nav-search-input');
  if (searchInput) {
    searchInput.addEventListener('keydown', e => { if (e.key === 'Enter') goSearch(); });
  }
}

function goSearch() {
  const q = document.getElementById('nav-search-input')?.value || '';
  window.location.href = `annonces.html?q=${encodeURIComponent(q)}`;
}

/* ─── INIT ─── */
document.addEventListener('DOMContentLoaded', () => {
  DB.init();
  injectLayout();
});
